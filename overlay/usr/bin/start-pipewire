#!/usr/bin/env bash
set -e
source /usr/lib/steam-headless/common-functions.sh
source /usr/lib/steam-headless/export-user-session-env.sh

wait_for_session_dbus

if [ -n "${PIPEWIRE_RENICE:-}" ] && command -v renice >/dev/null 2>&1; then
    renice -n "${PIPEWIRE_RENICE}" -p "$$" >/dev/null 2>&1 || \
        echo "Unable to renice PipeWire server to ${PIPEWIRE_RENICE}"
fi

exec /usr/bin/pipewire
