#!/usr/bin/env bash
set -e
source /usr/lib/steam-headless/common-functions.sh
source /usr/lib/steam-headless/export-user-session-env.sh

export WLR_BACKENDS="${WLR_BACKENDS:-drm,libinput}"
export LIBSEAT_BACKEND="${LIBSEAT_BACKEND:-seatd}"
export WLR_RENDERER="${WLR_RENDERER:-gles2}"
export WLR_LIBINPUT_NO_DEVICES="${WLR_LIBINPUT_NO_DEVICES:-1}"

wait_for_session_dbus
wait_for_command "PipeWire Pulse server at ${PULSE_SERVER}" pactl info
export GDK_BACKEND="wayland,x11"
export QT_QPA_PLATFORM="wayland;xcb"
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT="wayland"
export LABWC_UPDATE_ACTIVATION_ENV=yes

exec /usr/bin/labwc -m
